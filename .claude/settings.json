{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-push-tests.sh",
            "if": "Bash(git push*)",
            "timeout": 120,
            "statusMessage": "Ejecutando npm test antes de pushear..."
          }
        ]
      }
    ]
  }
}
